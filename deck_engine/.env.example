# Copy this file to deck_engine/.env (gitignored — never commit real credentials)
# and fill in real values. run_nightly.sh sources it before running the pipeline.

# Gmail account used to SEND the nightly email (SMTP + App Password, not OAuth —
# see deck_engine/emailer.py docstring for the one-time setup steps).
DECK_ENGINE_EMAIL_FROM="you@gmail.com"
DECK_ENGINE_SMTP_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Where the finished deck / error reports should land. Defaults to
# trevorjow@hotmail.com in config.py if omitted — override here if you want
# nightly runs to go somewhere else.
# DECK_ENGINE_EMAIL_TO="trevorjow@hotmail.com"

# Optional: absolute path to the claude binary if it's not on PATH in the
# shell this script runs under.
# DECK_ENGINE_CLAUDE_BIN="/usr/local/bin/claude"

# Optional: upgrade the optimize pass to Opus (~4-5x Sonnet cost — PRD §4 constraints).
# DECK_ENGINE_OPTIMIZE_MODEL="opus"

# ── PRD v4 amendment (2026-07-03) ────────────────────────────────────────────

# Optional: comma-separated friend email addresses for the nightly newsletter's
# Bcc list. Empty/unset = newsletter send is skipped entirely (Trevor's own
# copy still sends as normal). Never commit real addresses.
# DECK_ENGINE_NEWSLETTER_BCC="friend1@example.com,friend2@example.com"

# Optional: model tier for card-tag classification (T4) and mechanic-token
# extraction (S3) — deliberately cheap, not Opus/Sonnet.
# DECK_ENGINE_CARD_TAGGER_MODEL="haiku"

# Optional: synergy-density gate threshold (S3) — nonland cards that must match
# the commander's mechanic tokens before the deck passes without a repair pass.
# DECK_ENGINE_SYNERGY_GATE_THRESHOLD="25"

# Optional: T6 --resume session-chaining experiment. OFF by default — this is
# an instrumented A/B comparison Trevor runs deliberately, not a default
# behaviour change. See config.py's RESUME_SESSION_CHAINING comment.
# DECK_ENGINE_RESUME_CHAINING="true"
