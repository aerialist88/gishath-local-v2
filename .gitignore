bin/
engine-src/
venv/
__pycache__/
*.pyc
*.pyo
.env
*.xlsx
.DS_Store
logs/
server.log
*.db

# deck_engine — keep run_log.json (small, meaningful history), ignore the
# bulky/regeneratable Scryfall cache and per-run xlsx output.
deck_engine/state/scryfall_cards.json
deck_engine/state/scryfall_cache_meta.json
deck_engine/state/*.corrupt
deck_engine/state/*test*.json
deck_engine/output/
deck_engine/state/edhrec_cache/
deck_engine/state/mtg_comprehensive_rules.txt
deck_engine/state/mtg_comprehensive_rules_meta.json
deck_engine/state/simulations/

# Atelier UI — runtime state: art index is distilled from the Scryfall cache,
# atelier_runs/ are per-run post-mortems, ui_settings.json is the user's
# Guild-rules state (machine-local, holds email addresses).
deck_engine/state/atelier_art_index.json
deck_engine/state/atelier_runs/
deck_engine/state/ui_settings.json
_bashtest.txt

# Public gallery — generated by `make gallery` (atelier/publish.py) from the
# deck output; a build artifact, re-baked on each nightly run.
gallery_site/

# Forge rules engine + portable JDK for the match simulator (~800MB of
# downloaded binaries; see atelier/forge_engine.py for what lives here).
third_party/

# Local Claude Code settings — machine-specific, not shared.
.claude/

# Card Kingdom price cache — regenerated by ck_price.py (background refresher
# or refresh_ck_prices.py), ~6MB, not meaningful to diff/version.
state/
